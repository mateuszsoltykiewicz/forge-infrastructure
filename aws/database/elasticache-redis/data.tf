# ==============================================================================
# ElastiCache Redis Module - Data Sources
# ==============================================================================
# This file handles auto-discovery of AWS region, account, and network resources.
# ==============================================================================

# ------------------------------------------------------------------------------
# Current AWS Region and Account
# ------------------------------------------------------------------------------

data "aws_region" "current" {}

data "aws_caller_identity" "current" {}

data "aws_partition" "current" {}

# ------------------------------------------------------------------------------
# Availability Zones
# ------------------------------------------------------------------------------

data "aws_availability_zones" "available" {
  state = "available"
}

# ------------------------------------------------------------------------------
# VPC Configuration
# ------------------------------------------------------------------------------

data "aws_vpc" "main" {
  id = var.vpc_id
}
